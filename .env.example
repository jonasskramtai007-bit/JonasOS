# Auth
# Random string used to sign session cookies and as the x-api-secret value.
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# The single password that unlocks the dashboard at /login.
DASHBOARD_PASSWORD=

# Supabase (server-only; the service role key bypasses RLS)
SUPABASE_URL=https://khjafjvfpcuhwyljnbzf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# AI features (Claude Haiku 4.5): capture classification, review
# drafts, identity sentence, daily prompt.
# Optional — without it, captures stay in the inbox and drafts are skipped.
ANTHROPIC_API_KEY=

# Daily prompt cron (see vercel.json). Vercel sends
# Authorization: Bearer ${CRON_SECRET} automatically when this is set.
CRON_SECRET=
# Email delivery via Resend (free tier) — the daily prompt recipient.
RESEND_API_KEY=
NOTIFY_EMAIL=
# Optional: local hour gate for the prompt (cron schedule stays UTC in
# vercel.json; the route skips unless the hour matches when this is set).
USER_TIMEZONE=Europe/Vilnius
PROMPT_HOUR=21
